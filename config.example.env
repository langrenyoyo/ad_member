# Taku OpenAPI (从 Taku 开发者后台 -> 账号管理 获取 Publisher Key)
TAKU_PUBLISHER_KEY=your_publisher_key_here
TAKU_API_BASE=https://openapi.toponad.com

# 站点后台 API (bulvchengshiios.heciguangnian.cn)
SITE_BASE_URL=https://bulvchengshiios.heciguangnian.cn
SITE_USERNAME=qdmin
SITE_PASSWORD=your_password_here

# App client API signing
APP_API_AUTH_ENABLED=1
APP_API_KEY=ad_member_app
APP_API_SECRET=replace_with_a_random_32_byte_secret
APP_API_TIME_WINDOW_SECONDS=300
